#!/usr/bin/env bun
import { formatError } from "../src/core/error.js";
import { main } from "../src/core/main.js";

main()
  .catch(async (e) => {
    console.error(formatError(e));
    process.exit(1);
  })
  .then((code) => {
    if (typeof code === "number") {
      process.exit(code);
    }
  });
