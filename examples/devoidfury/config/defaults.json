{
  "log_level": "warn",
  "log_target": "stderr",
  "default_model": "ai365/dsv4",
  "thinker": " 🧠 ... {}",
  "toolfmt": " 🔧 {} {}",
  "hide_tools": true,
  "show_token_use": true,
  "skills_path": "/skills",
  "extension_paths": ["builtins"],
  "extension_autoload": true,
  "default_subcommand": "cli",
  "chat_timeout_secs": 900,
  "profiles": {
    "default": {
      "blacklist-tools": ["explore"]
    },
    "explorer": {
      "model": "ai365/lfm2.5-8b-a1b",
      "blacklist-tools": ["write", "model", "explore"]
    },
    "generate": {
      "model": "ai365/qwen3.6-35b:general"
    },
    "fixer": {
      "model": "ai365/qwen3.6-27b"
    },
    "test": {
      "model": "ai365/qwen3.5-4b:coder"
    }
  },
  "agents-md": {
    "enabled": true,
    "autoload": false
  },
  "ui-interactive-cli": {
    "shell-mode": true
  },
  "websocket": {
    "port": 3000,
    "host": "0.0.0.0",
    "session-timeout-min": 30,
    "question-timeout-secs": 300,
    "question-strategy": "wait"
  },
  "webui": {
    "port": 3000,
    "host": "0.0.0.0",
    "session-token-ttl-min": 1440
  },
  "mcp-servers": [
    {
      "enabled": false,
      "name": "bun-docs-mcp",
      "url": "https://bun.com/docs/mcp"
    }
  ],
