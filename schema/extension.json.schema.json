{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oa-agent.dev/schemas/extension.json",
  "title": "Extension Metadata",
  "description": "Schema for extension.json metadata files in the oa-agent extension system",
  "type": "object",
  "required": ["name", "provides"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Unique extension identifier"
    },
    "provides": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Capabilities this extension provides (e.g., 'tools', 'cli:subcommands')"
    },
    "loadOrder": {
      "type": "number",
      "minimum": 0,
      "description": "Load order priority — lower values loaded first"
    },
    "dependsOn": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Extension names this extension depends on"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the extension"
    },
    "autoload": {
      "type": "boolean",
      "default": true,
      "description": "Whether to auto-discover and load this extension"
    },
    "enabled": {
      "type": "boolean",
      "description": "Whether the extension is enabled"
    },
    "configSchema": {
      "description": "JSON Schema (draft 2020-12) defining the extension's configuration options",
      "type": "object",
      "unevaluatedProperties": false
    },
    "cli:subcommands": {
      "description": "CLI subcommands declared by this extension. These are discovered at startup without loading extension code.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Subcommand name (e.g., 'info', 'show-prompt')"
          },
          "description": {
            "type": "string",
            "description": "Short description shown in help text"
          },
          "requiresConfig": {
            "type": "boolean",
            "default": true,
            "description": "Whether config should be loaded before the handler runs"
          },
          "requiresCore": {
            "type": "boolean",
            "default": false,
            "description": "Whether the full core object is needed by the handler"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Option name (e.g., '--json', '--session-id')"
                },
                "type": {
                  "type": "string",
                  "enum": ["boolean", "string", "number"],
                  "description": "Option type"
                },
                "description": {
                  "type": "string",
                  "description": "Option description for help text"
                }
              }
            },
            "description": "Subcommand-specific options for help text"
          }
        }
      }
    },
    "cli:flags": {
      "description": "CLI flags declared by this extension. These are discovered at startup without loading extension code.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["long"],
        "additionalProperties": false,
        "properties": {
          "short": {
            "type": "string",
            "description": "Short flag (e.g., '-x')"
          },
          "long": {
            "type": "string",
            "description": "Long flag (e.g., '--my-flag')"
          },
          "description": {
            "type": "string",
            "description": "Help text for this flag"
          },
          "type": {
            "type": "string",
            "enum": ["string", "boolean", "number", "array"],
            "default": "string",
            "description": "Flag type"
          },
          "default": {
            "description": "Default value when flag is not provided"
          }
        }
      }
    }
  }
}
