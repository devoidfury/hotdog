{
  "baseUrl": {
    "type": "string",
    "layers": [
      { "source": "provider", "path": "url" },
      { "source": "cli", "key": "aiUrl" },
      { "source": "config", "key": "aiUrl" },
      { "source": "env", "key": "AI_URL" },
      { "source": "env", "key": "HOTDOG_AI_URL" },
      { "default": null }
    ]
  },
  "apiKey": {
    "type": "string",
    "layers": [
      { "source": "provider", "path": "apiKey" },
      { "source": "cli", "key": "apiKey" },
      { "source": "config", "key": "apiKey" },
      { "source": "env", "key": "AI_API_KEY" },
      { "default": null }
    ]
  },
  "thinkerFormat": {
    "type": "string",
    "cliFlag": {
      "short": "-t",
      "long": "--thinker",
      "type": "string",
      "description": "Thinking format string"
    },
    "layers": [
      { "source": "cli", "key": "thinker" },
      { "source": "config", "key": "thinker" },
      { "default": "[Thinking: {}]" }
    ]
  },
  "toolFormat": {
    "type": "string",
    "cliFlag": {
      "long": "--toolfmt",
      "type": "string",
      "description": "Tool call format string"
    },
    "layers": [
      { "source": "cli", "key": "toolfmt" },
      { "source": "config", "key": "toolfmt" },
      { "default": "  \u2192 {} {}" }
    ]
  },
  "toolOutputFmt": {
    "type": "string",
    "cliFlag": {
      "long": "--tool-output-fmt",
      "type": "string",
      "description": "Tool result format string"
    },
    "layers": [
      { "source": "cli", "key": "toolOutputFmt" },
      { "source": "config", "key": "toolOutputFmt" },
      { "default": "----\n{}\n----" }
    ]
  },
  "chatTimeout": {
    "type": "number",
    "cliFlag": {
      "long": "--chat-timeout",
      "type": "number",
      "description": "Chat request timeout in seconds"
    },
    "layers": [
      { "source": "cli", "key": "chatTimeout" },
      { "source": "config", "key": "chatTimeoutSecs" },
      { "default": 600 }
    ]
  },
  "embeddingsTimeout": {
    "type": "number",
    "cliFlag": {
      "long": "--embeddings-timeout",
      "type": "number",
      "description": "Embeddings request timeout in seconds"
    },
    "layers": [
      { "source": "cli", "key": "embeddingsTimeout" },
      { "source": "config", "key": "embeddingsTimeoutSecs" },
      { "default": 120 }
    ]
  },
  "sessionId": {
    "type": "string",
    "cliFlag": {
      "short": "-s",
      "long": "--session-id",
      "type": "string",
      "description": "Resumable session ID"
    },
    "layers": [{ "source": "cli", "key": "sessionId" }, { "default": null }]
  },
  "compactDebug": {
    "type": "boolean",
    "cliFlag": {
      "long": "--compact-debug",
      "type": "boolean",
      "description": "Write compaction output to compaction.out.json"
    },
    "layers": [
      { "source": "cli", "key": "compactDebug", "cast": "truthy" },
      { "source": "config", "key": "compactDebug" },
      { "default": false }
    ]
  },
  "noLog": {
    "type": "boolean",
    "cliFlag": {
      "long": "--no-log",
      "type": "boolean",
      "description": "Disable session logging"
    },
    "layers": [
      { "source": "cli", "key": "noLog", "cast": "truthy" },
      {
        "source": "env",
        "key": "HOTDOG_LOG",
        "cast": "falsy"
      },
      {
        "source": "env",
        "key": "HOTDOG_NO_LOG",
        "cast": "truthy"
      },
      { "source": "config", "key": "noLog" },
      { "default": false }
    ]
  },
  "showTokenUse": {
    "type": "boolean",
    "cliFlag": {
      "long": "--tokens",
      "type": "boolean",
      "description": "Display token usage stats"
    },
    "layers": [
      { "source": "cli", "key": "tokens", "cast": "truthy" },
      {
        "source": "config",
        "key": "showTokenUse",
        "cast": "any"
      },
      { "default": true }
    ]
  },
  "stream": {
    "type": "boolean",
    "cliFlag": {
      "long": "--no-stream",
      "type": "boolean",
      "description": "Disable streaming"
    },
    "layers": [
      { "source": "cli", "key": "noStream", "cast": "falsy" },
      { "default": true }
    ]
  },
  "hideTools": {
    "type": "boolean",
    "cliFlag": {
      "long": "--show-tools",
      "type": "boolean",
      "description": "Show tool calls"
    },
    "layers": [
      { "source": "cli", "key": "showTools", "cast": "falsy" },
      { "source": "cli", "key": "hideTools", "cast": "any" },
      { "source": "config", "key": "hideTools" },
      { "default": true }
    ]
  },
  "hideThinking": {
    "type": "boolean",
    "cliFlag": {
      "long": "--hide-thinking",
      "type": "boolean",
      "description": "Hide thinking output"
    },
    "layers": [
      { "source": "cli", "key": "showThinking", "cast": "falsy" },
      { "source": "cli", "key": "hideThinking", "cast": "any" },
      {
        "source": "config",
        "key": "hideThinking",
        "cast": "any"
      },
      { "default": false }
    ]
  },
  "useColors": {
    "type": "boolean",
    "cliFlag": {
      "long": "--colors",
      "type": "boolean",
      "description": "Enable colors"
    },
    "layers": [
      {
        "source": "cli",
        "key": "noColors",
        "cast": "falsy"
      },
      {
        "source": "cli",
        "key": "colors",
        "cast": "truthy"
      },
      {
        "source": "config",
        "key": "colors",
        "cast": "any"
      },
      { "default": true }
    ]
  },
  "theme": {
    "type": "string",
    "cliFlag": {
      "long": "--theme",
      "type": "string",
      "description": "Theme (dark, light, monochrome, or file path)"
    },
    "layers": [
      {
        "source": "cli",
        "key": "theme",
        "cast": "string"
      },
      {
        "source": "config",
        "key": "theme",
        "cast": "string"
      },
      { "default": "dark" }
    ]
  },
  "role": {
    "type": "string",
    "cliFlag": {
      "long": "--role",
      "type": "string",
      "description": "System prompt role"
    },
    "layers": [
      {
        "source": "cli",
        "key": "role",
        "cast": "string"
      },
      {
        "source": "config",
        "key": "role",
        "cast": "string"
      },
      {
        "source": "profile",
        "key": "role",
        "cast": "string"
      },
      {
        "default": "You are an AI coding assistant. Use the instructions below and the tools available to you to assist the user."
      }
    ]
  },
  "aspects": {
    "type": "array",
    "layers": [
      { "source": "profile", "key": "aspects", "cast": "array" },
      { "default": [] }
    ]
  },
  "defaultModel": {
    "type": "string",
    "layers": [
      { "source": "cli", "key": "model", "cast": "string" },
      { "source": "profile", "key": "model", "cast": "string" },
      { "source": "config", "key": "defaultModel", "cast": "string" },
      { "default": "qwen3.5-0.8b" }
    ]
  },
  "maxIterations": {
    "type": "number",
    "cliFlag": {
      "long": "--max-iterations",
      "type": "number",
      "description": "Maximum agent loop iterations"
    },
    "layers": [
      { "source": "cli", "key": "maxIterations", "cast": "number" },
      { "source": "config", "key": "maxIterations", "cast": "number" },
      { "default": 1000 }
    ]
  },
  "maxRetries": {
    "type": "number",
    "layers": [{ "default": 12 }]
  },
  "prompt": {
    "type": "string",
    "layers": [{ "default": "> " }]
  },
  "exitCommands": {
    "type": "array",
    "layers": [{ "default": ["exit", "quit"] }]
  },
  "taskProfile": {
    "type": "string",
    "layers": [{ "default": "task-default" }]
  },
  "coreTools": {
    "type": "object",
    "layers": [
      { "source": "config", "key": "coreTools" },
      { "default": {} }
    ]
  },
  "compaction": {
    "type": "object",
    "layers": [
      { "source": "config", "key": "compaction" },
      { "default": {} }
    ]
  },
  "hookTrace": {
    "type": "boolean",
    "cliFlag": {
      "long": "--hook-trace",
      "type": "boolean",
      "description": "Trace hook execution (requires HOTDOG_LOG_LEVEL=debug)"
    },
    "layers": [
      { "source": "cli", "key": "hookTrace", "cast": "truthy" },
      { "source": "env", "key": "HOTDOG_HOOK_TRACE", "cast": "truthy" },
      { "source": "config", "key": "hookTrace" },
      { "default": false }
    ]
  },
  "profileName": {
    "type": "string",
    "cliFlag": {
      "long": "--profile",
      "type": "string",
      "description": "Profile name"
    },
    "layers": [
      { "source": "cli", "key": "profile" },
      { "source": "config", "key": "profile" },
      { "default": "default" }
    ]
  },
  "profilesPath": {
    "type": "string",
    "cliFlag": {
      "long": "--profiles-path",
      "type": "string",
      "description": "Profiles directory path"
    },
    "layers": [
      { "source": "cli", "key": "profilesPath" },
      { "source": "config", "key": "profilesPath" },
      { "compute": "joinConfigDir:profiles" }
    ]
  },
  "provider": {
    "type": "string",
    "cliFlag": {
      "long": "--provider",
      "type": "string",
      "description": "Provider name"
    },
    "layers": [
      { "source": "cli", "key": "provider" },
      { "source": "config", "key": "defaultProvider" },
      { "default": null }
    ]
  },
  "systemPromptTemplate": {
    "type": "string",
    "cliFlag": {
      "long": "--system-prompt-template",
      "type": "string",
      "description": "System prompt template file path"
    },
    "layers": [
      { "source": "cli", "key": "systemPromptTemplate" },
      { "source": "config", "key": "systemPromptTemplate" },
      { "default": null }
    ]
  },
  "profiles": {
    "type": "object",
    "layers": [{ "source": "config", "key": "profiles" }, { "default": {} }]
  },
  "extensionPaths": {
    "type": "array",
    "layers": [
      { "source": "config", "key": "extensionPaths" },
      { "default": ["builtins"] }
    ]
  },
  "extensionAutoload": {
    "type": "boolean",
    "layers": [
      { "source": "config", "key": "extensionAutoload" },
      { "default": false }
    ]
  },
  "extensions": {
    "type": "array",
    "layers": [{ "source": "config", "key": "extensions" }, { "default": [] }]
  },
  "defaultSubcommand": {
    "type": "string",
    "layers": [
      { "source": "config", "key": "defaultSubcommand" },
      { "default": "cli" }
    ]
  },
  "temperature": {
    "type": "number",
    "layers": [
      { "source": "config", "key": "temperature" },
      { "default": null }
    ]
  },
  "defaultProvider": {
    "type": "string",
    "layers": [
      { "source": "config", "key": "defaultProvider" },
      { "default": null }
    ]
  },
  "defaultAiUrl": {
    "type": "string",
    "layers": [{ "default": "http://localhost:8080" }]
  },
  "taskDefaultRole": {
    "type": "string",
    "layers": [{ "default": "A focused worker that executes tasks autonomously" }]
  },
  "systemPromptDefaultTemplate": {
    "type": "string",
    "layers": [{ "default": "{{ role }}\n\n{{ body }}\n{% for chunk in chunks %}{{ chunk.content }}{% endfor %}" }]
  }
}
