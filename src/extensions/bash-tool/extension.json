{
  "name": "bash-tool",
  "provides": ["tools"],
  "loadOrder": 1,
  "description": "Bash tool — execute shell commands",
  "configSchema": {
    "type": "object",
    "properties": {
      "bashTimeoutMs": {
        "type": "number",
        "default": 60000,
        "description": "Default timeout for bash commands in milliseconds"
      },
      "maxToolOutputLines": {
        "type": "number",
        "default": 600,
        "description": "Maximum number of output lines for tool results"
      }
    },
    "additionalProperties": false
  }
}
