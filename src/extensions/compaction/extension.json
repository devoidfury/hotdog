{
  "name": "compaction",
  "provides": [],
  "loadOrder": 10,
  "dependsOn": ["core-tools"],
  "description": "Context compaction strategies (summarize, drop, token-aware)",
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Whether compaction is enabled"
      },
      "reserveTokens": {
        "type": "number",
        "default": 8000,
        "description": "Token budget to reserve for the conversation"
      },
      "keepRecentMessages": {
        "type": "number",
        "default": 3,
        "description": "Number of recent messages to keep after compaction"
      },
      "strategy": {
        "type": "string",
        "default": "summarize",
        "enum": ["summarize", "drop", "summarize-short", "token-aware"],
        "description": "Compaction strategy to use"
      }
    },
    "additionalProperties": false
  }
}
