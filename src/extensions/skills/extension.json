{
  "name": "skills",
  "provides": ["tools"],
  "loadOrder": 10,
  "dependsOn": ["core-tools"],
  "description": "Skills loading, activation, and system prompt integration",
  "cli:flags": [
    {
      "long": "--preload-skills",
      "type": "array",
      "description": "Preload skills by name (comma-separated)"
    }
  ],
  "configSchema": {
    "skills": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether this extension is enabled. Set to false to disable the extension entirely."
        },
        "preloadSkills": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "layers": [
            { "source": "cli", "key": "preloadSkills" },
            { "source": "config", "key": "skills.preloadSkills" }
          ],
          "description": "List of skill names to preload"
        },
        "path": {
          "type": "string",
          "description": "Directory path where skills are stored",
          "layers": [
            { "source": "config", "key": "skills.path" },
            { "source": "config", "key": "skillsPath" },
            { "compute": "joinConfigDir:skills" }
          ]
        }
      },
      "additionalProperties": false,
      "layers": [{ "source": "config", "key": "skills" }, { "default": {} }]
    }
  }
}
