{
  "name": "ui-session-review-cli",
  "provides": ["cli:subcommands", "tools"],
  "loadOrder": 10,
  "description": "Provides the review CLI subcommand and review tool for session log inspection",
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Whether this extension is enabled. Set to false to disable the extension entirely."
      }
    },
    "additionalProperties": false
  },
  "cli:flags": [
    {
      "long": "--tool-index",
      "type": "boolean",
      "description": "Show tool usage index"
    }
  ],
  "cli:subcommands": [
    {
      "name": "review",
      "description": "Review session logs",
      "options": [
        {
          "name": "--session-id",
          "type": "string",
          "description": "Session ID to review"
        },
        {
          "name": "--json",
          "type": "boolean",
          "description": "Output in JSON format"
        },
        {
          "name": "--tool-index",
          "type": "boolean",
          "description": "Show tool usage index"
        }
      ]
    }
  ]
}
