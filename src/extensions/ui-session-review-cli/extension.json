{
  "name": "ui-session-review-cli",
  "provides": ["cli:subcommands", "tools"],
  "loadOrder": 10,
  "description": "Provides the sessions CLI subcommand (show, delete, cleanup) and review tool for session log management",
  "configSchema": {
    "uiSessionReviewCli": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether this extension is enabled. Set to false to disable the extension entirely."
        }
      },
      "additionalProperties": false,
      "layers": [
        { "source": "config", "key": "uiSessionReviewCli" },
        { "default": {} }
      ]
    }
  },
  "cli:flags": [
    {
      "long": "--tool-index",
      "type": "boolean",
      "description": "Show tool usage index"
    },
    {
      "long": "--older-than",
      "type": "number",
      "description": "Number of days (for sessions cleanup)"
    },
    {
      "long": "--yes",
      "type": "boolean",
      "description": "Skip confirmation prompt (for sessions delete/cleanup)"
    }
  ],
  "cli:subcommands": [
    {
      "name": "sessions",
      "description": "Manage session logs (show, delete, cleanup)",
      "options": [
        {
          "name": "--session-id",
          "type": "string",
          "description": "Session ID to show"
        },
        {
          "name": "--json",
          "type": "boolean",
          "description": "Output in JSON format"
        },
        {
          "name": "--tool-index",
          "type": "boolean",
          "description": "Show tool usage index"
        },
        {
          "name": "--older-than",
          "type": "number",
          "description": "Days threshold for cleanup"
        },
        {
          "name": "--yes",
          "type": "boolean",
          "description": "Skip confirmation prompt"
        }
      ]
    }
  ]
}
