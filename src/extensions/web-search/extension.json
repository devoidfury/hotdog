{
  "name": "web-search",
  "provides": ["tools"],
  "loadOrder": 10,
  "description": "Web search tool — search the internet via DuckDuckGo, Brave, Tavily, or SearXNG",
  "configSchema": {
    "webSearch": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether this extension is enabled"
        },
        "provider": {
          "type": "string",
          "default": "duckduckgo",
          "description": "Search provider: duckduckgo, brave, tavily, or searxng",
          "enum": ["duckduckgo", "brave", "tavily", "searxng"]
        },
        "maxResults": {
          "type": "number",
          "default": 5,
          "description": "Maximum number of search results to return (1-10)"
        },
        "timeout": {
          "type": "number",
          "default": 15,
          "description": "Request timeout in seconds"
        },
        "braveApiKey": {
          "type": "string",
          "default": "",
          "description": "Brave Search API key (required when provider=brave)",
          "layers": [
            { "source": "config", "key": "webSearch.braveApiKey" },
            { "source": "env", "key": "BRAVE_API_KEY" },
            { "default": "" }
          ]
        },
        "tavilyApiKey": {
          "type": "string",
          "default": "",
          "description": "Tavily API key (required when provider=tavily)",
          "layers": [
            { "source": "config", "key": "webSearch.tavilyApiKey" },
            { "source": "env", "key": "TAVILY_API_KEY" },
            { "default": "" }
          ]
        },
        "searxngInstanceUrl": {
          "type": "string",
          "default": "",
          "description": "SearXNG instance URL (e.g. https://searx.example.com) (required when provider=searxng)",
          "layers": [
            { "source": "config", "key": "webSearch.searxngInstanceUrl" },
            { "source": "env", "key": "SEARXNG_INSTANCE_URL" },
            { "default": "" }
          ]
        }
      },
      "additionalProperties": false,
      "layers": [
        { "source": "config", "key": "webSearch" },
        { "default": {} }
      ]
    }
  }
}
